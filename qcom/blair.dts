/dts-v1/;

/ {
	model = "Qualcomm Technologies, Inc. Blair SoC";
	compatible = "qcom,blair";
	qcom,msm-id = <0x1fb 0x10000 0x242 0x10000>;
	interrupt-parent = <0x01>;
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	qcom,board-id = <0x00 0x00>;

	chosen {
		bootargs = "loglevel=6 log_buf_len=256K swiotlb=noforce kernel.panic_on_rcu_stall=1 rcupdate.rcu_expedited=1 fw_devlink.strict=1 service_locator.enable=1 rcu_nocbs=0-7 kpti=off irqaffinity=0-1 nosoftlockup cpufreq.default_governor=performance sysctl.kernel.sched_pelt_multiplier=4 no-steal-acc cgroup.memory=nokmem,nosocket printk.console_no_auto_verbose=1 kasan=off loop.max_part=7 can.stats_timer=0 ftrace_dump_on_oops ufshcd-core.use_mcq_mode=n firmware_class.path=/vendor/firmware_mnt/image pcie_ports=compat disable_dma32=on kcompactd_cpumask=0xff";
	};

	memory {
		device_type = "memory";
		reg = <0x00 0x00 0x00 0x00>;
	};

	firmware {
		phandle = <0x15c>;

		qcom_scm {
			compatible = "qcom,scm";
			qcom,dload-mode = <0x02 0x13000>;
		};

		android {
			compatible = "android,firmware";

			vbmeta {
				compatible = "android,vbmeta";
				parts = "vbmeta,boot,system,vendor,dtbo";
			};

			fstab {
				compatible = "android,fstab";

				vendor {
					compatible = "android,vendor";
					dev = "/dev/block/platform/soc/4744000.sdhci/by-name/vendor";
					type = "ext4";
					mnt_flags = "ro,barrier=1,discard";
					fsmgr_flags = "wait,avb";
					status = "ok";
				};
			};
		};
	};

	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;
		phandle = <0x15d>;

		hyp_region@80000000 {
			no-map;
			reg = <0x00 0x80000000 0x00 0x600000>;
			phandle = <0x15e>;
		};

		xblboot_region@80700000 {
			no-map;
			reg = <0x00 0x80700000 0x00 0x100000>;
			phandle = <0x15f>;
		};

		reserved_region@80880000 {
			no-map;
			reg = <0x00 0x80880000 0x00 0x4000>;
			phandle = <0x160>;
		};

		minidump_uefixbl_region@80884000 {
			no-map;
			reg = <0x00 0x80884000 0x00 0x10000>;
			phandle = <0x161>;
		};

		smem@80900000 {
			compatible = "qcom,smem";
			reg = <0x00 0x80900000 0x00 0x200000>;
			hwlocks = <0x03 0x03>;
			no-map;
			phandle = <0x162>;
		};

		cpucp_fw_region@80b00000 {
			no-map;
			reg = <0x00 0x80b00000 0x00 0x100000>;
			phandle = <0x163>;
		};

		wlan_region@86500000 {
			no-map;
			reg = <0x00 0x86500000 0x00 0x200000>;
			phandle = <0x164>;
		};

		adsp_region@86700000 {
			no-map;
			reg = <0x00 0x86700000 0x00 0x2a00000>;
			phandle = <0x7f>;
		};

		cdsp_region@89100000 {
			no-map;
			reg = <0x00 0x89100000 0x00 0x1e00000>;
			phandle = <0x82>;
		};

		video_region@8af00000 {
			no-map;
			reg = <0x00 0x8af00000 0x00 0x700000>;
			phandle = <0x165>;
		};

		ipa_fw_region@8b600000 {
			no-map;
			reg = <0x00 0x8b600000 0x00 0x10000>;
			phandle = <0x166>;
		};

		ipa_gsi_region@8b610000 {
			no-map;
			reg = <0x00 0x8b610000 0x00 0xa000>;
			phandle = <0x167>;
		};

		gpu_microcode_region@8b61a000 {
			no-map;
			reg = <0x00 0x8b61a000 0x00 0x2000>;
			phandle = <0x168>;
		};

		mpsswlan_region@8b800000 {
			no-map;
			reg = <0x00 0x8b800000 0x00 0x10000000>;
			phandle = <0x85>;
		};

		tz_stat_region@c0000000 {
			no-map;
			reg = <0x00 0xc0000000 0x00 0x100000>;
			phandle = <0x169>;
		};

		tags_region@c0100000 {
			no-map;
			reg = <0x00 0xc0100000 0x00 0x1200000>;
			phandle = <0x16a>;
		};

		qtee_region@c1300000 {
			no-map;
			reg = <0x00 0xc1300000 0x00 0x500000>;
			phandle = <0x16b>;
		};

		trusted_apps_region@c1800000 {
			no-map;
			reg = <0x00 0xc1800000 0x00 0x8400000>;
			phandle = <0x16c>;
		};

		secure_display_region {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			reusable;
			alignment = <0x00 0x400000>;
			size = <0x00 0x5c00000>;
			phandle = <0x16d>;
		};

		debug_kinfo_region {
			alloc-ranges = <0x00 0x00 0xffffffff 0xffffffff>;
			size = <0x00 0x1000>;
			no-map;
			phandle = <0x78>;
		};

		va_md_mem_region {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			reusable;
			size = <0x00 0x1000000>;
			phandle = <0x77>;
		};

		ramoops {
			compatible = "ramoops";
			reg = <0x00 0xd0000000 0x00 0x200000>;
			pmsg-size = <0x200000>;
			mem-type = <0x02>;
			phandle = <0x16e>;
		};

		linux,cma {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			reusable;
			alignment = <0x00 0x400000>;
			size = <0x00 0x2000000>;
			linux,cma-default;
			phandle = <0x2d>;
		};

		adsp_region {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			reusable;
			alignment = <0x00 0x400000>;
			size = <0x00 0x800000>;
			phandle = <0x97>;
		};

		qseecom_region {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			reusable;
			alignment = <0x00 0x400000>;
			size = <0x00 0x1400000>;
			phandle = <0x23>;
		};

		qseecom_ta_region {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			reusable;
			alignment = <0x00 0x400000>;
			size = <0x00 0x1000000>;
			phandle = <0x24>;
		};

		memshare_region {
			compatible = "shared-dma-pool";
			no-map;
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			alignment = <0x00 0x100000>;
			size = <0x00 0x800000>;
			phandle = <0x16f>;
		};

		non_secure_display_region {
			compatible = "shared-dma-pool";
			reusable;
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			size = <0x00 0x5c00000>;
			alignment = <0x00 0x400000>;
			phandle = <0x22>;
		};

		mem_dump_region {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			reusable;
			size = <0x00 0x800000>;
			phandle = <0xcb>;
		};

		dfps_data_region {
			phandle = <0x27a>;
			label = "dfps_data_region";
			reg = <0x00 0x85e00000 0x00 0x100000>;
		};
	};

	aliases {
		swr1 = "/soc/spf_core_platform/bolero-codec/rx-macro@A600000/rx_swr_master";
		swr0 = "/soc/spf_core_platform/bolero-codec/va-macro@A730000/va_swr_master";
		serial0 = "/soc/qcom,qupv3_1_geni_se@4cc0000/qcom,qup_uart@4c8c000";
		hsuart0 = "/soc/qcom,qupv3_0_geni_se@4ac0000/qcom,qup_uart@4a84000";
		ufshc1 = "/soc/ufshc@4804000";
		mmc0 = "/soc/sdhci@4744000";
		mmc1 = "/soc/sdhci@4784000";
		phandle = <0x170>;
	};

	cpus {
		#address-cells = <0x02>;
		#size-cells = <0x00>;

		cpu@0 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x00>;
			enable-method = "psci";
			cpu-idle-states = <0x04 0x05>;
			power-domains = <0x06>;
			power-domain-names = "psci";
			cpu-release-addr = <0x00 0x50000000>;
			next-level-cache = <0x07>;
			qcom,freq-domain = <0x08 0x00>;
			dynamic-power-coefficient = <0x64>;
			capacity-dmips-mhz = <0x400>;
			#cooling-cells = <0x02>;
			phandle = <0x1a>;

			l2-cache {
				compatible = "arm,arch-cache";
				cache-level = <0x02>;
				next-level-cache = <0x09>;
				phandle = <0x07>;

				l3-cache {
					compatible = "arm,arch-cache";
					cache-level = <0x03>;
					phandle = <0x09>;
				};
			};
		};

		cpu@100 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x100>;
			enable-method = "psci";
			cpu-idle-states = <0x04 0x05>;
			power-domains = <0x0a>;
			power-domain-names = "psci";
			cpu-release-addr = <0x00 0x50000000>;
			next-level-cache = <0x0b>;
			qcom,freq-domain = <0x08 0x00>;
			dynamic-power-coefficient = <0x64>;
			capacity-dmips-mhz = <0x400>;
			#cooling-cells = <0x02>;
			phandle = <0x1b>;

			l2-cache {
				compatible = "arm,arch-cache";
				cache-level = <0x02>;
				next-level-cache = <0x09>;
				phandle = <0x0b>;
			};
		};

		cpu@200 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x200>;
			enable-method = "psci";
			cpu-idle-states = <0x04 0x05>;
			power-domains = <0x0c>;
			power-domain-names = "psci";
			cpu-release-addr = <0x00 0x50000000>;
