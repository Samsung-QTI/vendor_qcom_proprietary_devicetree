				phandle = <0x0f>;
			};
		};

		cpu@400 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x400>;
			enable-method = "psci";
			cpu-idle-states = <0x04 0x05>;
			power-domains = <0x10>;
			power-domain-names = "psci";
			cpu-release-addr = <0x00 0x50000000>;
			next-level-cache = <0x11>;
			qcom,freq-domain = <0x08 0x00>;
			dynamic-power-coefficient = <0x64>;
			capacity-dmips-mhz = <0x400>;
			#cooling-cells = <0x02>;
			phandle = <0x1e>;

			l2-cache {
				compatible = "arm,arch-cache";
				cache-level = <0x02>;
				next-level-cache = <0x09>;
				phandle = <0x11>;
			};
		};

		cpu@500 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x500>;
			enable-method = "psci";
			cpu-idle-states = <0x04 0x05>;
			power-domains = <0x12>;
			power-domain-names = "psci";
			cpu-release-addr = <0x00 0x50000000>;
			next-level-cache = <0x13>;
			qcom,freq-domain = <0x08 0x00>;
			dynamic-power-coefficient = <0x64>;
			capacity-dmips-mhz = <0x400>;
			#cooling-cells = <0x02>;
			phandle = <0x1f>;

			l2-cache {
				compatible = "arm,arch-cache";
				cache-level = <0x02>;
				next-level-cache = <0x09>;
				phandle = <0x13>;
			};
		};

		cpu@600 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x600>;
			enable-method = "psci";
			cpu-idle-states = <0x14 0x15>;
			power-domains = <0x16>;
			power-domain-names = "psci";
			cpu-release-addr = <0x00 0x50000000>;
			next-level-cache = <0x17>;
			qcom,freq-domain = <0x08 0x01>;
			dynamic-power-coefficient = <0x208>;
			capacity-dmips-mhz = <0x79a>;
			#cooling-cells = <0x02>;
			phandle = <0x20>;

			l2-cache {
				compatible = "arm,arch-cache";
				cache-level = <0x02>;
				next-level-cache = <0x09>;
				phandle = <0x17>;
			};
		};

		cpu@700 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x700>;
			enable-method = "psci";
			cpu-idle-states = <0x14 0x15>;
			power-domains = <0x18>;
			power-domain-names = "psci";
			cpu-release-addr = <0x00 0x50000000>;
			next-level-cache = <0x19>;
			qcom,freq-domain = <0x08 0x01>;
			dynamic-power-coefficient = <0x208>;
			capacity-dmips-mhz = <0x79a>;
			#cooling-cells = <0x02>;
			phandle = <0x21>;

			l2-cache {
				compatible = "arm,arch-cache";
				cache-level = <0x02>;
				next-level-cache = <0x09>;
				phandle = <0x19>;
			};
		};

		cpu-map {

			cluster0 {

				core0 {
					cpu = <0x1a>;
				};

				core1 {
					cpu = <0x1b>;
				};

				core2 {
					cpu = <0x1c>;
				};

				core3 {
					cpu = <0x1d>;
				};

				core4 {
					cpu = <0x1e>;
				};

				core5 {
					cpu = <0x1f>;
				};
			};

			cluster1 {

				core0 {
					cpu = <0x20>;
				};

				core1 {
					cpu = <0x21>;
				};
			};
		};
	};

	idle-states {
		entry-method = "psci";

		silver-c3 {
			compatible = "arm,idle-state";
			idle-state-name = "pc";
			entry-latency-us = <0x225>;
			exit-latency-us = <0x385>;
			min-residency-us = <0x6ee>;
			arm,psci-suspend-param = <0x40000003>;
			local-timer-stop;
			phandle = <0x04>;
		};

		silver-cluster0-c4 {
			compatible = "arm,idle-state";
			idle-state-name = "rail-pc";
			entry-latency-us = <0x2be>;
			exit-latency-us = <0x393>;
			min-residency-us = <0xfa1>;
			arm,psci-suspend-param = <0x40000004>;
			local-timer-stop;
			phandle = <0x05>;
		};

		gold-c3 {
			compatible = "arm,idle-state";
			idle-state-name = "pc";
			entry-latency-us = <0x20b>;
			exit-latency-us = <0x4dc>;
			min-residency-us = <0x89f>;
			arm,psci-suspend-param = <0x40000003>;
			local-timer-stop;
			phandle = <0x14>;
		};

		gold-cluster1-c4 {
			compatible = "arm,idle-state";
			idle-state-name = "rail-pc";
			entry-latency-us = <0x20e>;
			exit-latency-us = <0x73e>;
			min-residency-us = <0x15b3>;
			arm,psci-suspend-param = <0x40000004>;
			local-timer-stop;
			phandle = <0x15>;
		};

		cluster-d4 {
			compatible = "domain-idle-state";
			idle-state-name = "l3-pc";
			entry-latency-us = <0xac0>;
			exit-latency-us = <0xbde>;
			min-residency-us = <0x17e6>;
			arm,psci-suspend-param = <0x41000044>;
			phandle = <0x31>;
		};
	};

	soc {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges = <0x00 0x00 0x00 0xffffffff>;
		compatible = "simple-bus";
		phandle = <0x171>;

		qcom,dma-heaps {
			compatible = "qcom,dma-heaps";

			qcom,display {
				qcom,dma-heap-name = "qcom,display";
				qcom,dma-heap-type = <0x02>;
				qcom,max-align = <0x09>;
				memory-region = <0x22>;
			};

			qcom,qseecom {
				qcom,dma-heap-name = "qcom,qseecom";
				qcom,dma-heap-type = <0x02>;
				memory-region = <0x23>;
			};

			qcom,qseecom_ta {
				qcom,dma-heap-name = "qcom,qseecom-ta";
				qcom,dma-heap-type = <0x02>;
				memory-region = <0x24>;
			};
		};

		arm,smmu-kgsl@5940000 {
			compatible = "qcom,smmu-v2\0qcom,adreno-smmu";
			reg = <0x5940000 0x10000>;
			#iommu-cells = <0x01>;
			qcom,use-3-lvl-tables;
			#global-interrupts = <0x02>;
			qcom,regulator-names = "vdd";
			vdd-supply = <0x25>;
			clock-names = "gcc_gpu_memnoc_gfx_clk";
			clocks = <0x26 0x63>;
			interrupts = <0x00 0x17b 0x04 0x00 0x17d 0x04 0x00 0x1c9 0x04 0x00 0x1ca 0x04 0x00 0x1cb 0x04 0x00 0x1cc 0x04 0x00 0x1cd 0x04 0x00 0x1ce 0x04 0x00 0x1cf 0x04 0x00 0x1d0 0x04>;
			attach-impl-defs = <0x6000 0x2378 0x6060 0x1055 0x678c 0x08 0x6794 0x28 0x6800 0x06 0x6900 0x3ff 0x6924 0x204 0x6928 0x11000 0x6930 0x800 0x6960 0xffffffff 0x6b64 0x1a5551 0x6b68 0x9a82a382>;
			phandle = <0x2f>;
		};

		apps-smmu@0c600000 {
			compatible = "qcom,qsmmu-v500";
			reg = <0xc600000 0x100000 0xc702000 0x20>;
			reg-names = "base\0tcu-base";
			#iommu-cells = <0x02>;
			qcom,skip-init;
			qcom,use-3-lvl-tables;
			qcom,handoff-smrs = <0x820 0x02>;
			#global-interrupts = <0x01>;
			#size-cells = <0x01>;
			#address-cells = <0x01>;
			ranges;
