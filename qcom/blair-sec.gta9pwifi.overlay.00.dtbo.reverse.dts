	fragment@32 {
		phandle = <0xbc>;
		target = <0xffffffff>;

		__overlay__ {

			cam_flash_strobe_active {
				phandle = <0x7d>;

				mux {
					function = "gpio";
					pins = "gpio51";
				};

				config {
					drive-strength = <0x02>;
					bias-disable;
					pins = "gpio51";
				};
			};

			cam_flash_strobe_suspend {
				phandle = <0x7e>;

				mux {
					function = "gpio";
					pins = "gpio51";
				};

				config {
					output-low;
					drive-strength = <0x02>;
					bias-pull-down;
					pins = "gpio51";
				};
