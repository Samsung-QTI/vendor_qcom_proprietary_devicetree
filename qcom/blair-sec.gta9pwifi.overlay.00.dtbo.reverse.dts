/dts-v1/;

/ {
	model = "Samsung GTA9PWiFi PROJECT (board-id,00)";
	compatible = "qcom,blair-qrd\0qcom,blair\0qcom,qrd";
	qcom,msm-id = <0x1fb 0x10000 0x242 0x10000>;
	qcom,board-id = <0x1000b 0x00>;
	qcom,pmic-id-size = <0x04>;
	qcom,pmic-id = <0x2d 0x00 0x00 0x00>;

	fragment@0 {
		target = <0xffffffff>;

		__overlay__ {

			qcom,pm6125@0 {
				compatible = "qcom,spmi-pmic";
				reg = <0x00 0x00>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				qcom,power-on@800 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x800>;
					interrupts = <0x00 0x08 0x00 0x03 0x00 0x08 0x01 0x03>;
					interrupt-names = "kpdpwr\0resin";
					qcom,pon-dbc-delay = <0x3d09>;
					qcom,kpdpwr-sw-debounce;
					qcom,system-reset;
					qcom,store-hard-reset-reason;
					qcom,log-kpd-event;
					phandle = <0x28>;

					qcom,pon_1 {
						qcom,pon-type = <0x00>;
						qcom,pull-up;
						linux,code = <0x74>;
					};

					qcom,pon_2 {
						qcom,pon-type = <0x01>;
						qcom,pull-up;
						linux,code = <0x72>;
					};
				};

				sdam@b000 {
					compatible = "qcom,spmi-sdam";
					reg = <0xb000>;
					#address-cells = <0x01>;
					#size-cells = <0x01>;
					phandle = <0x29>;
				};

				vadc@3100 {
					compatible = "qcom,spmi-adc5";
					reg = <0x3100>;
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					interrupts = <0x00 0x31 0x00 0x01>;
					interrupt-names = "eoc-int-en-set";
					#io-channel-cells = <0x01>;
					io-channel-ranges;
					pinctrl-names = "default";
					pinctrl-0 = <0x01 0x02 0x03 0x04>;
					phandle = <0x05>;

					ref_gnd {
						reg = <0x00>;
						label = "ref_gnd";
						qcom,pre-scaling = <0x01 0x01>;
					};

					vref_1p25 {
						reg = <0x01>;
						label = "vref_1p25";
						qcom,pre-scaling = <0x01 0x01>;
					};

					die_temp {
						reg = <0x06>;
						label = "die_temp";
						qcom,pre-scaling = <0x01 0x01>;
					};

					vph_pwr {
						reg = <0x83>;
						label = "vph_pwr";
						qcom,pre-scaling = <0x01 0x03>;
					};

					pa_therm1 {
						reg = <0x4d>;
						label = "pa_therm1";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};

					quiet_therm {
						reg = <0x4e>;
						label = "quiet_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};

					pa_therm2 {
						reg = <0x55>;
						label = "pa_therm2";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};

					msm_therm {
						reg = <0x52>;
						label = "msm_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};

					batt_id {
						reg = <0x34>;
						label = "batt_id";
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};

					chg_therm {
						reg = <0x53>;
						label = "chg_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};
				};

				adc_tm@3500 {
					compatible = "qcom,spmi-adc-tm5";
					reg = <0x3500>;
					interrupts = <0x00 0x35 0x00 0x01>;
					interrupt-names = "pm-adc-tm5";
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					#thermal-sensor-cells = <0x01>;
					phandle = <0x0e>;

					pa_therm2 {
						reg = <0x00>;
						io-channels = <0x05 0x55>;
						qcom,ratiometric;
						qcom,hw-settle-time-us = <0xc8>;
					};

					pa_therm1 {
						reg = <0x01>;
						io-channels = <0x05 0x4d>;
						qcom,ratiometric;
						qcom,hw-settle-time-us = <0xc8>;
					};

					quiet_therm {
						reg = <0x03>;
						io-channels = <0x05 0x4e>;
						qcom,ratiometric;
						qcom,hw-settle-time-us = <0xc8>;
					};
				};

				qcom,temp-alarm@2400 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0x2400>;
					interrupts = <0x00 0x24 0x00 0x03>;
					io-channels = <0x05 0x06>;
					io-channel-names = "thermal";
					#thermal-sensor-cells = <0x00>;
					phandle = <0x07>;
				};

				clock-controller@5b00 {
					compatible = "qcom,spmi-clkdiv";
					reg = <0x5b00>;
					#clock-cells = <0x01>;
					qcom,num-clkdivs = <0x01>;
					clock-output-names = "pm6125_div_clk1";
					clocks = <0xffffffff 0x00>;
					clock-names = "xo";
					assigned-clocks = <0x06 0x01>;
					assigned-clock-rates = <0x927c00>;
					phandle = <0x06>;
				};

				pinctrl@c000 {
					compatible = "qcom,pm6125-gpio";
					reg = <0xc000>;
					gpio-controller;
					#gpio-cells = <0x02>;
					interrupt-controller;
					#interrupt-cells = <0x02>;
					phandle = <0x16>;

					pa_therm2 {

						pa_therm2_default {
							pins = "gpio7";
							bias-high-impedance;
							phandle = <0x01>;
						};
					};

					msm_therm {

						msm_therm_default {
							pins = "gpio3";
							bias-high-impedance;
							phandle = <0x02>;
						};
					};

					batt_id {

						batt_id_default {
							pins = "gpio6";
							bias-high-impedance;
							phandle = <0x04>;
						};
					};

					chg_therm {

						chg_therm_default {
							pins = "gpio4";
							bias-high-impedance;
							phandle = <0x03>;
						};
					};

					afc_switch {

						afc_switch_default {
							pins = "gpio5";
							function = "normal";
							power-source = <0x00>;
							output-low;
							input-disable;
							phandle = <0x17>;
						};
					};
				};

				qcom,pm6125_rtc {
					compatible = "qcom,pm8941-rtc";
					interrupts = <0x00 0x61 0x01 0x00>;
					phandle = <0x2a>;
				};
			};

			qcom,pm6125@1 {
				compatible = "qcom,spmi-pmic";
				reg = <0x01 0x00>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				qcom,pwms@b300 {
					status = "disabled";
					compatible = "qcom,pwm-lpg";
					reg = <0xb300>;
					reg-names = "lpg-base";
					qcom,num-lpg-channels = <0x01>;
					#pwm-cells = <0x02>;
					phandle = <0x2b>;
				};
			};
		};
	};

	fragment@1 {
		target = <0xffffffff>;

		__overlay__ {

			pm6125_tz {
				polling-delay-passive = <0x64>;
				polling-delay = <0x00>;
				thermal-governor = "step_wise";
				thermal-sensors = <0x07>;

				trips {

					trip0 {
						temperature = <0x17318>;
						hysteresis = <0x00>;
						type = "passive";
						phandle = <0x2c>;
					};

					trip1 {
						temperature = <0x1c138>;
						hysteresis = <0x00>;
						type = "critical";
						phandle = <0x2d>;
					};

					trip2 {
						temperature = <0x23668>;
						hysteresis = <0x00>;
						type = "critical";
						phandle = <0x2e>;
					};
				};
			};
		};
	};

	fragment@2 {
		target = <0xffffffff>;

		__overlay__ {
			#address-cells = <0x02>;
			#size-cells = <0x00>;
			interrupt-controller;
			#interrupt-cells = <0x04>;

			qcom,pmr735a@4 {
				compatible = "qcom,spmi-pmic";
				reg = <0x04 0x00>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				qcom,temp-alarm@a00 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0xa00>;
					interrupts = <0x04 0x0a 0x00 0x03>;
					#thermal-sensor-cells = <0x00>;
					phandle = <0x08>;
				};

				pinctrl@8800 {
					compatible = "qcom,pmr735a-gpio";
					reg = <0x8800>;
					gpio-controller;
					#gpio-cells = <0x02>;
					interrupt-controller;
					#interrupt-cells = <0x02>;
					phandle = <0x12>;

					key_vol_up {

						key_vol_up_default {
							pins = "gpio1";
							function = "normal";
							input-enable;
							bias-pull-up;
							power-source = <0x01>;
							phandle = <0x11>;
						};
					};

					usb_therm {

						usb_therm_default {
							pins = "gpio3";
							bias-high-impedance;
							phandle = <0x0b>;
						};
					};

					pmx_sde {
						phandle = <0x154>;

						sde_dsi_default {
							phandle = <0x11f>;
							output-low;
							bias-disable;
							power-source = <0x01>;
							qcom,drive-strength = <0x02>;
							function = "func1";
							pins = "gpio2";
						};
					};
				};
			};
		};
	};

	fragment@3 {
		target = <0xffffffff>;

		__overlay__ {

			pmr735a_tz {
				polling-delay-passive = <0x64>;
				polling-delay = <0x00>;
				thermal-governor = "step_wise";
				thermal-sensors = <0x08>;
				phandle = <0x2f>;

				trips {

					trip0 {
						temperature = <0x17318>;
						hysteresis = <0x00>;
						type = "passive";
						phandle = <0x30>;
					};

					trip1 {
						temperature = <0x1c138>;
						hysteresis = <0x00>;
						type = "critical";
						phandle = <0x31>;
					};

					trip2 {
						temperature = <0x23668>;
						hysteresis = <0x00>;
						type = "critical";
						phandle = <0x32>;
					};
				};
			};
		};
	};

	fragment@4 {
		target = <0xffffffff>;

		__overlay__ {
			#address-cells = <0x02>;
			#size-cells = <0x00>;
			interrupt-controller;
			#interrupt-cells = <0x04>;

			qcom,pmk8350@0 {
				compatible = "qcom,spmi-pmic";
				reg = <0x06 0x00>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				phandle = <0x33>;

				pon_pbs@800 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x800>;
					qcom,system-reset;
					qcom,store-hard-reset-reason;
					status = "disabled";
				};

				pon_hlos@1300 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x1300>;
					interrupts = <0x00 0x13 0x07 0x03 0x00 0x13 0x06 0x03>;
					interrupt-names = "kpdpwr\0resin";
					status = "disabled";

					qcom,pon_1 {
						qcom,pon-type = <0x00>;
						linux,code = <0x74>;
					};

					qcom,pon_2 {
						qcom,pon-type = <0x01>;
						linux,code = <0x72>;
					};
				};

				vadc@3100 {
					compatible = "qcom,spmi-adc7";
					reg = <0x3100>;
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					interrupts = <0x06 0x31 0x00 0x01>;
					interrupt-names = "eoc-int-en-set";
					#io-channel-cells = <0x01>;
					io-channel-ranges;
					phandle = <0x09>;

					pmk8350_ref_gnd {
						reg = <0x600>;
						label = "pmk8350_ref_gnd";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pmk8350_vref_1p25 {
						reg = <0x601>;
						label = "pmk8350_vref_1p25";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pmk8350_die_temp {
						reg = <0x603>;
						label = "pmk8350_die_temp";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pmk8350_xo_therm {
						reg = <0x644>;
						label = "pmk8350_xo_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};

					pmk8350_vbus_dect {
						reg = <0x647>;
						label = "vbus_dect";
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};
				};

				adc_tm@3400 {
					compatible = "qcom,spmi-adc-tm5-gen2";
					reg = <0x3400>;
					interrupts = <0x06 0x34 0x00 0x01>;
					interrupt-names = "threshold";
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					#thermal-sensor-cells = <0x01>;
					io-channels = <0x09 0x644>;
					phandle = <0x0f>;

					xo_therm {
						reg = <0x00>;
						io-channels = <0x09 0x644>;
						qcom,ratiometric;
						qcom,hw-settle-time-us = <0xc8>;
					};
				};

				sdam@7100 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7100>;
					#address-cells = <0x01>;
					#size-cells = <0x01>;
					phandle = <0x34>;

					restart@48 {
						reg = <0x48 0x01>;
						bits = <0x01 0x07>;
						phandle = <0x35>;
					};
				};

				sdam@7400 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7400>;
					phandle = <0x36>;
				};

				sdam@7c00 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7c00>;
					phandle = <0x37>;
				};

				sdam@7d00 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7d00>;
					phandle = <0x38>;
				};

				sdam@8400 {
					compatible = "qcom,spmi-sdam";
					reg = <0x8400>;
					phandle = <0x39>;
				};

				sdam@8500 {
					compatible = "qcom,spmi-sdam";
					reg = <0x8500>;
					phandle = <0x3a>;
				};

				sdam@9800 {
					compatible = "qcom,spmi-sdam";
					reg = <0x9800>;
					phandle = <0x3b>;
				};

				sdam@9d00 {
					compatible = "qcom,spmi-sdam";
					reg = <0x9d00>;
					phandle = <0x3c>;
				};

				pinctrl@b000 {
					compatible = "qcom,pmk8350-gpio";
					reg = <0xb000>;
					gpio-controller;
					#gpio-cells = <0x02>;
					interrupt-controller;
					#interrupt-cells = <0x02>;
					phandle = <0x3d>;

					vbus_dect {

						pmk8350_vbus_dect {
							pins = "gpio3";
							bias-high-impedance;
							phandle = <0x3e>;
						};
					};
				};

				rtc@6100 {
					compatible = "qcom,pmk8350-rtc";
					reg = <0x6100 0x6200>;
					reg-names = "rtc\0alarm";
					interrupts = <0x06 0x62 0x01 0x01>;
					phandle = <0x3f>;
				};
			};
		};
	};

	fragment@5 {
		target = <0xffffffff>;

		__overlay__ {

			qcom,pmr735a@4 {

				adc_tm@3400 {
					compatible = "qcom,spmi-adc-tm5-iio";
					reg = <0x3400>;
					#thermal-sensor-cells = <0x01>;
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					phandle = <0x0d>;

					usb_conn_therm {
						reg = <0x00>;
						io-channels = <0x0a 0x4c>;
						qcom,ratiometric;
						qcom,hw-settle-time-us = <0xc8>;
					};
				};

				vadc@3600 {
					compatible = "qcom,spmi-adc7-sw-calib";
					reg = <0x3600 0x3900>;
					reg-names = "adc5-sw-calib-pbs-base\0adc5-sw-calib-cmn-base";
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					interrupts = <0x04 0x36 0x00 0x01>;
					interrupt-names = "eoc";
					#io-channel-cells = <0x01>;
					io-channel-ranges;
					status = "ok";
					pinctrl-names = "default";
					pinctrl-0 = <0x0b>;
					phandle = <0x0a>;

					usb_conn_therm {
						reg = <0x4c>;
						label = "usb_conn_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};

					pmr735a_ref_gnd {
						reg = <0x00>;
						label = "pmr735a_ref_gnd";
						qcom,pre-scaling = <0x01 0x01>;
						qcom,no-cal;
					};

					pmr735a_vref_1p25 {
						reg = <0x01>;
						label = "pmr735a_vref_1p25";
						qcom,pre-scaling = <0x01 0x01>;
						qcom,no-cal;
					};

					pmr735a_vref_vdd {
						reg = <0x02>;
						label = "pmr735a_vref_vdd";
						qcom,pre-scaling = <0x01 0x01>;
						qcom,no-cal;
					};

					pmr735a_die_temp {
						reg = <0x03>;
						label = "pmr735a_die_temp";
						qcom,pre-scaling = <0x01 0x01>;
					};
				};
			};
		};
	};

	fragment@6 {
		target = <0xffffffff>;

		__overlay__ {

			qcom,pm6125@0 {

				adc_tm@3400 {
					compatible = "qcom,spmi-adc-tm5-iio";
					reg = <0x3400>;
					#thermal-sensor-cells = <0x01>;
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					phandle = <0x0c>;

					msm_therm {
						reg = <0x00>;
						io-channels = <0x05 0x52>;
						qcom,ratiometric;
						qcom,hw-settle-time-us = <0xc8>;
					};

					chg_therm {
						reg = <0x01>;
						io-channels = <0x05 0x53>;
						qcom,ratiometric;
						qcom,hw-settle-time-us = <0xc8>;
					};
				};
			};
		};
	};

	fragment@7 {
		target = <0xffffffff>;

		__overlay__ {

			sdm-skin-therm {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x0c 0x00>;

				trips {

					active-config0 {
						temperature = <0x1e848>;
						hysteresis = <0x3e8>;
						type = "passive";
					};
				};
			};

			chg-therm {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x0c 0x01>;

				trips {

					active-config0 {
						temperature = <0x1e848>;
						hysteresis = <0x3e8>;
						type = "passive";
					};
				};
			};

			usb-conn-therm {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x0d 0x00>;

				trips {

					active-config0 {
						temperature = <0x1e848>;
						hysteresis = <0x3e8>;
						type = "passive";
					};
				};
			};

			quiet-therm {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x0e 0x03>;

				trips {

					active-config0 {
						temperature = <0x1e848>;
						hysteresis = <0x3e8>;
						type = "passive";
					};

					active-config1 {
						temperature = <0x1e848>;
						hysteresis = <0x3e8>;
						type = "passive";
					};
				};
			};

			pa-therm0 {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x0e 0x01>;

				trips {

					active-config0 {
						temperature = <0x1e848>;
						hysteresis = <0x3e8>;
						type = "passive";
					};
				};
			};

			pa-therm1 {
				polling-delay-passive = <0x00>;
