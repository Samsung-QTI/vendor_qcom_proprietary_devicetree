					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio23";
					};
				};

				sde_te_suspend {
					phandle = <0x121>;

					mux {
						function = "MDP_VSYNC";
						pins = "gpio23";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio23";
					};
				};
			};
		};
	};

