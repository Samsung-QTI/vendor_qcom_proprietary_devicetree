	fragment@17 {
		target = <0xffffffff>;

		__overlay__ {

			rt1711pd_int_n {
				phandle = <0x1f>;

				mux {
					pins = "gpio11";
					function = "gpio";
				};

				config {
					pins = "gpio11";
					drive-strength = <0x08>;
					bias-pull-up;
				};
			};

			afc {

				afc_data_default {
					phandle = <0x18>;

					mux {
						pins = "gpio37";
						function = "gpio";
					};

					config {
						pins = "gpio37";
						drive-strength = <0x10>;
						bias-disable;
					};
				};

				afc_data_active {
					phandle = <0x19>;

					mux {
						pins = "gpio37";
						function = "gpio";
					};

					config {
						pins = "gpio37";
						drive-strength = <0x10>;
						bias-disable;
					};
				};

				afc_data_sleep {
					phandle = <0x1a>;

					mux {
						pins = "gpio37";
						function = "gpio";
					};

					config {
						pins = "gpio37";
						bias-disable;
						input-enable;
						drive-strength = <0x10>;
					};
				};
			};

			authon_default {
				phandle = <0x1b>;

				mux {
					pins = "gpio102";
					function = "gpio";
				};

				config {
					pins = "gpio102";
					drive-strength = <0x10>;
					bias-disable;
				};
			};

			authon_active {
				phandle = <0x1c>;

				mux {
					pins = "gpio102";
					function = "gpio";
				};

				config {
					pins = "gpio102";
					drive-strength = <0x10>;
					bias-pull-up;
				};
			};

			authon_sleep {
				phandle = <0x1d>;

				mux {
					pins = "gpio102";
					function = "gpio";
				};

				config {
					pins = "gpio102";
					bias-disable;
					input-enable;
					drive-strength = <0x10>;
				};
			};
		};
	};

